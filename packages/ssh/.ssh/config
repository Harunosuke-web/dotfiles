# GitHub サブアカウント用。remoteは git@github-sub:<アカウント名>/... を使う
Host github-sub
  HostName github.com
  User git
  IdentityFile ~/.ssh/github-sub.pub
  IdentitiesOnly yes

# GitHub 既定 (Harunosuke-web アカウント)。1Passwordエージェントに鍵が2つあるため、
# 固定しないと先に提示された鍵（サブ鍵）で認証されて Harunosuke-web への push が拒否される。
Host github.com
  User git
  IdentityFile ~/.ssh/harunosuke-web.pub
  IdentitiesOnly yes

Host *
  IdentityAgent ~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock
